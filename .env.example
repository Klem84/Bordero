# Modèle de variables d'environnement (Bordero)
# Copier ce fichier en .env.local et renseigner les vraies valeurs.
# .env.local est ignoré par git : il ne doit JAMAIS être commité.

# --- Supabase (projet bordero-staging, région UE Frankfurt) ---
NEXT_PUBLIC_SUPABASE_URL=https://votre-ref.supabase.co

# Clé publishable : côté client, exposée au navigateur (équivalent anon).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Clé secrète : SERVEUR UNIQUEMENT, accès admin total à la base.
# Ne jamais préfixer NEXT_PUBLIC_, ne jamais l'exposer au client.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Mot de passe de la base (utilisé par la CLI pour les migrations).
SUPABASE_DB_PASSWORD=xxx

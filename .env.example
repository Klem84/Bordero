# Modèle de variables d'environnement (Bordero)
# Copier en .env.local et renseigner les vraies valeurs. .env.local est ignoré par git.

# --- Supabase (projet bordero-staging, région UE) ---
NEXT_PUBLIC_SUPABASE_URL=https://votre-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_DB_PASSWORD=xxx

# --- Mapbox (cartes, routage, matrices) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx

# --- SMS + email d'appoint (Brevo) ---
BREVO_API_KEY=xkeysib-xxx

# --- Mobile (Expo / EAS, surtout pour la CI) ---
EXPO_TOKEN=xxx

# --- Paiement (Stripe, mode test) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Monitoring (optionnel) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Déploiement (CI uniquement, jamais au runtime de l'app) ---
# VERCEL_TOKEN et GitHub PAT restent hors de l'app : voir Acces.txt.
